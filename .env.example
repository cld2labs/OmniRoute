# OmniRoute environment template
# Copy this file to `.env` and update the values that apply to your setup.
#
# Supported provider values in this project:
# - openai
# - openai_compatible
#
# Which fields you need to change:
# 1. If you use OpenAI for chat:
#    - LLM_PROVIDER
#    - LLM_MODEL
#    - LLM_API_KEY
#    - LLM_BASE_URL
#
# 2. If you use Ollama or another OpenAI-compatible API for chat:
#    - LLM_PROVIDER
#    - LLM_MODEL
#    - LLM_API_KEY
#    - LLM_BASE_URL
#
# 3. If you use OpenAI for embeddings:
#    - EMBEDDING_PROVIDER
#    - EMBEDDING_MODEL
#    - EMBEDDING_DIM
#    - EMBEDDING_API_KEY
#    - EMBEDDING_BASE_URL
#
# 4. If you use Ollama or another OpenAI-compatible API for embeddings:
#    - EMBEDDING_PROVIDER
#    - EMBEDDING_MODEL
#    - EMBEDDING_DIM
#    - EMBEDDING_API_KEY
#    - EMBEDDING_BASE_URL
#
# Notes:
# - For local Ollama, the API key is usually not enforced. You can still set it
#   to a placeholder value like `ollama`.
# - If OmniRoute runs through Docker Compose and Ollama runs on your host
#   machine, use `http://host.docker.internal:11434/v1` instead of
#   `http://localhost:11434/v1`.
# - If OmniRoute runs directly on your host machine without Docker, use
#   `http://localhost:11434/v1`.
# - If your embeddings provider uses a different vector size, you must update
#   EMBEDDING_DIM to match the model output dimension exactly.

# Core app
DATABASE_URL=postgresql+asyncpg://omnroute:omnroute@postgres:5432/omnroute

# API and web
API_PORT=8000
WEB_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM
# Default configuration uses OpenAI chat models.
#
# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
#
# Ollama example if OmniRoute runs directly on your host:
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=qwen3:4b
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
#
# Ollama example if OmniRoute runs with Docker Compose and Ollama runs on the host:
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=qwen3:4b
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
#
# Any other OpenAI-compatible API:
# Change these exact fields:
# - LLM_PROVIDER=openai_compatible
# - LLM_MODEL=<your_model_name>
# - LLM_API_KEY=<your_api_key>
# - LLM_BASE_URL=<your_base_url>/v1
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

# Embeddings
# Default configuration uses OpenAI embeddings.
#
# OpenAI example:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
# EMBEDDING_API_KEY=your_openai_api_key_here
# EMBEDDING_BASE_URL=https://api.openai.com/v1
#
# Ollama or another OpenAI-compatible embeddings API:
# Change these exact fields:
# - EMBEDDING_PROVIDER=openai_compatible
# - EMBEDDING_MODEL=<your_embedding_model_name>
# - EMBEDDING_DIM=<your_embedding_dimension>
# - EMBEDDING_API_KEY=<your_api_key_or_placeholder>
# - EMBEDDING_BASE_URL=<your_base_url>/v1
#
# Example if OmniRoute runs directly on your host:
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://localhost:11434/v1
#
# Example if OmniRoute runs with Docker Compose and Ollama runs on the host:
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=your_openai_api_key_here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=30

# Data Engine
DATA_ENGINE_MODE=run
DATA_ENGINE_TICK_INTERVAL_SECONDS=30
DATA_ENGINE_SEED_IF_EMPTY=true
DATA_ENGINE_SEED_ROUTES=6
DATA_ENGINE_SEED_DAYS=3
DATA_ENGINE_BOOKING_RATE_PER_TICK=3.0
DATA_ENGINE_CANCELLATION_RATE_PER_TICK=0.8
DATA_ENGINE_INCIDENT_RATE_PER_TICK=0.4
DATA_ENGINE_DELAY_SENSITIVITY=1.0
DATA_ENGINE_ENABLE_CASCADING_DELAYS=true
